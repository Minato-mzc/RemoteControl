# ---- Rust (workspace) ----
target/
server-pc/target/
# Cargo.lock kept — these are binaries, lockfile is desirable

# Auto-generated demo artifacts
server-pc/qrcode.html
server-pc/test_capture.h264

# ---- Android (app-android) ----
*.iml
.gradle/
.kotlin/
*.salive
local.properties
.idea/
.DS_Store
app-android/build/
app-android/app/build/
app-android/captures/
app-android/.externalNativeBuild
app-android/.cxx
# Release signing — keystore is the private key for the published app
# identity; passwords live in keystore.properties next to it. Losing
# either means the same package can never publish an update again,
# but committing them is even worse. Both must stay local.
*.jks
*.keystore
keystore.properties

# ---- Release artifacts ----
# Populated by installer/build-installer.ps1 — signed installer .exe,
# standalone server .exe, and signed Android APK. All regenerable,
# none of them belong in git.
/dist/

# ---- Misc ----
.vscode/
.claude/
*.log
